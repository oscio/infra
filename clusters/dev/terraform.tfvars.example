# Copy to terraform.tfvars and edit. DO NOT commit terraform.tfvars.
#
# Layout: cluster basics → TLS mode → one section per app.
# Each app section is self-contained (enable + auth + storage + flags).
# Apps depend on each other (Keycloak before Forgejo/Harbor/Grafana,
# etc.) but the order below is purely visual.


# =====================================================================
# Cluster basics
# =====================================================================
# Every hostname (auth.<domain>, cr.<domain>, git.<domain>, …) is
# derived from `domain`. For local dev with no DNS, `127.0.0.1.nip.io`
# works; remember to update `traefik_extra_listener_hostnames` to match.
# =====================================================================

domain          = "dev.example.com"
kubeconfig_path = "~/.kube/config"
kube_context    = "docker-desktop"

# hostpath (Docker Desktop), standard (kind), local-path (k3d/k3s),
# gp3 (EKS), "" for cluster default.
storage_class = "hostpath"

gateway_api_enabled  = true
traefik_service_type = "LoadBalancer"

# Per-VM workspace pods land at <vm-id>.vm.<domain>.
# Gateway API wildcards only match one DNS label, so this deeper
# wildcard listener is required. EDIT to match `domain`.
traefik_extra_listener_hostnames = ["*.vm.dev.example.com"]


# =====================================================================
# TLS mode
# =====================================================================
# "off"                 → plain HTTP (kind/dev throwaway only)
# "selfsigned"          → cert-manager-issued internal CA + wildcard
# "letsencrypt-staging" → ACME staging (fake CA, useful for dry-runs)
# "letsencrypt-prod"    → ACME prod (real trusted certs)
# Letsencrypt modes additionally require letsencrypt_email + DNS-01
# provider + matching credentials.
# =====================================================================

tls_mode = "selfsigned"

letsencrypt_email       = ""
dns_provider            = "none" # "cloudflare" for letsencrypt-* wildcards, "none" otherwise
cloudflare_api_token    = ""
gateway_tls_secret_name = ""


# =====================================================================
# Platform Postgres (shared backend for Keycloak/Forgejo/Harbor/etc.)
# =====================================================================

platform_postgres_superuser_password = "CHANGE-ME"
platform_postgres_storage_size       = "8Gi"


# =====================================================================
# Keycloak — IdP for everything below
# =====================================================================

# Two-phase realm seed:
#   Phase 1: realm_enabled = false (Keycloak comes up).
#   Phase 2: realm_enabled = true  (seeds platform realm + clients +
#            users). Apply twice on the first install.
realm_enabled = false

# Master realm admin.
keycloak_admin_username = "admin"
keycloak_admin_password = "CHANGE-ME"

# DB role (in the shared platform Postgres).
keycloak_db_password = "CHANGE-ME"

# --- Platform realm metadata ---
keycloak_realm_name            = "platform"
keycloak_realm_display_name    = "Agent Platform"
keycloak_realm_password_policy = "" # set e.g. "length(12) and digits(1) and upperCase(1)" for prod

# --- Platform realm groups ---
keycloak_realm_groups = ["platform-admin"]

# --- Platform realm users ---
# Members of `platform-admin` auto-promote to admin in Forgejo/Harbor/
# Grafana on every OIDC login. Username intentionally NOT "admin".
keycloak_realm_users = {
  "johndoe" = {
    email              = "johndoe@example.com"
    first_name         = "John"
    last_name          = "Doe"
    password           = "CHANGE-ME"
    password_temporary = true
    groups             = ["platform-admin"]
  }
  # "alice" = {
  #   email    = "alice@example.com"
  #   password = "CHANGE-ME"
  #   groups   = ["platform-admin"]
  # }
}


# =====================================================================
# oauth2-proxy — front-door for platform UIs, validates Keycloak sessions
# =====================================================================

oauth2_proxy_client_id     = "oauth2-proxy" # Keycloak OIDC client_id (realm + consumer share)
oauth2_proxy_client_secret = "CHANGE-ME"
oauth2_proxy_email_domains = ["*"] # restrict via e.g. ["example.com"]


# =====================================================================
# Forgejo — in-cluster Git
# =====================================================================

forgejo_enabled = false

forgejo_admin_username = "forgejo-admin"
forgejo_admin_email    = "forgejo-admin@example.com"
forgejo_admin_password = "CHANGE-ME"

forgejo_client_id          = "forgejo"
forgejo_oidc_client_secret = "CHANGE-ME"

forgejo_db_password = "CHANGE-ME"

forgejo_repo_storage_size     = "20Gi"
forgejo_postgres_storage_size = "8Gi"

forgejo_disable_registration = true        # rely on OIDC
forgejo_require_signin_view  = true        # no public browsing
forgejo_ssh_service_type     = "ClusterIP" # cluster-internal SSH only


# =====================================================================
# Forgejo Runner — Forgejo Actions executor (DinD-backed)
# =====================================================================

forgejo_runner_enabled  = false
forgejo_runner_replicas = 1

# Harbor robot creds for `docker buildx push`. Auto-provisioned by the
# harbor-bootstrap module — leave empty unless bypassing it.
forgejo_runner_registry_username = ""
forgejo_runner_registry_password = ""


# =====================================================================
# Forgejo forks — one-time clones from upstream
# =====================================================================
# Empty map = no forks. Use to iterate on a repo's Forgejo Actions
# workflow in-cluster without round-tripping through GitHub.

forgejo_fork_owner = "platform"
forgejo_fork_repos = {}
# Example:
# forgejo_fork_repos = {
#   "agent-sandbox" = {
#     clone_addr  = "https://github.com/<owner>/agent-sandbox"
#     description = "Forked from <owner>/agent-sandbox."
#   }
# }
# github_clone_username = ""    # set if any upstream is private
# github_clone_token    = ""    # GitHub PAT (read-only repo scope)


# =====================================================================
# Harbor — container registry
# =====================================================================

harbor_enabled = false

harbor_admin_username = "admin" # Harbor enforces this; cannot be changed
harbor_admin_password = "CHANGE-ME"
harbor_admin_email    = "admin@example.com"

harbor_client_id          = "harbor"
harbor_oidc_client_secret = "CHANGE-ME"
# selfsigned/letsencrypt-staging: must NOT verify Keycloak's cert.
harbor_oidc_verify_cert = false

harbor_db_password = "CHANGE-ME"

harbor_registry_storage_size = "50Gi"
harbor_database_storage_size = "8Gi"


# =====================================================================
# Keel — registry-driven Deployment auto-roller
# =====================================================================

# Basic auth on the dashboard at cd.<domain>. Built-in (no OIDC).
keel_admin_username = "admin"
keel_admin_password = "CHANGE-ME"


# =====================================================================
# Monitoring — Prometheus + Alertmanager + Grafana + Loki + Alloy
# =====================================================================

monitoring_enabled = false

grafana_admin_username     = "admin"
grafana_admin_password     = "CHANGE-ME"
grafana_admin_email        = "admin@example.com"
grafana_client_id          = "grafana"
grafana_oidc_client_secret = "CHANGE-ME"

monitoring_prometheus_storage_size   = "20Gi"
monitoring_prometheus_retention      = "15d"
monitoring_alertmanager_storage_size = "2Gi"
monitoring_grafana_storage_size      = "5Gi"
monitoring_loki_storage_size         = "20Gi"
monitoring_loki_retention            = "168h" # 7 days


# =====================================================================
# Console (services/console) — better-auth + Keycloak
# =====================================================================
# Flip on once the console hostname is real and the better-auth deployment
# is reachable. Until then, leave disabled — the OIDC client will not be
# registered and the platform stays self-consistent.

console_enabled            = false
console_client_id          = "console"
console_oidc_client_secret = "CHANGE-ME"

# Required when console_enabled = true (and realm_enabled = true).
# console_db_password        = "CHANGE-ME"               # `console` Postgres role
# console_better_auth_secret = "CHANGE-ME"               # `openssl rand -base64 32`

# Image tags. Pin to a SHA in production; `:latest` works with Keel-driven
# rollouts on push to main. The Forgejo workflow at
# services/console/.forgejo/workflows/build.yml builds and pushes both.
# console_web_image = "cr.dev.openschema.io/agent-platform/console-web:latest"
# console_api_image = "cr.dev.openschema.io/agent-platform/console-api:latest"


# =====================================================================
# OpenFGA — Zanzibar-style authorization engine
# =====================================================================

openfga_enabled     = false
openfga_db_password = "CHANGE-ME"


# =====================================================================
# hermes-agent (binary inside each VM / agent-sandbox pod) — Keycloak
# client. The Keycloak `hermes` client is the token-exchange source
# identity for impersonating users against downstream services.
# =====================================================================

hermes_client_id     = "hermes"
hermes_client_secret = "CHANGE-ME"
devpod_client_id     = "devpod"


# =====================================================================
# DevPod operator + CRD
# =====================================================================

devpod_operator_enabled        = false
devpod_operator_run_controller = false

# Image overrides (optional). Empty = derived from var.domain.
# devpod_operator_image = "devpod-operator:dev-<epoch>"
# devpod_default_image  = "devpod-base:dev-<epoch>"
